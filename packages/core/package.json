{
  "name": "@shiage/core",
  "version": "0.0.0",
  "description": "Framework-agnostic core for Shiage: CSS→Tailwind mapper, JSX AST editor, WebSocket protocol, diff generation.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jiti": "^2.7.0"
  },
  "peerDependencies": {
    "@tailwindcss/node": "^4",
    "tailwindcss": "^3 || ^4"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/node": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
