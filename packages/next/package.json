{
  "name": "@shiage/next",
  "version": "0.1.0",
  "description": "Next.js plugin for Shiage — inspect and edit CSS in Chrome DevTools, save changes to source as Tailwind classes.",
  "keywords": [
    "next",
    "nextjs",
    "next-plugin",
    "tailwind",
    "tailwindcss",
    "css",
    "devtools",
    "dx",
    "webpack",
    "shiage"
  ],
  "homepage": "https://shiage.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/horacechoi/shiage.git",
    "directory": "packages/next"
  },
  "bugs": "https://github.com/horacechoi/shiage/issues",
  "license": "MIT",
  "author": "Horace Choi",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@shiage/core": "workspace:*",
    "@shiage/jsx-transform": "workspace:*",
    "@shiage/runtime": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "webpack": "^5.99.0"
  }
}
