{
  "name": "@shiage/jsx-transform",
  "version": "0.1.0",
  "description": "Babel plugin that stamps data-shiage-loc source-location attributes onto JSX host elements.",
  "keywords": [
    "babel-plugin",
    "jsx",
    "tsx",
    "source-location",
    "data-attribute",
    "shiage"
  ],
  "homepage": "https://shiage.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/horacechoi/shiage.git",
    "directory": "packages/jsx-transform"
  },
  "bugs": "https://github.com/horacechoi/shiage/issues",
  "license": "MIT",
  "author": "Horace Choi",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@babel/core": "^7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.0",
    "@types/node": "^25.9.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
