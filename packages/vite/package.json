{
  "name": "@shiage/vite",
  "version": "0.0.0",
  "description": "Vite plugin for Shiage — inspect and edit CSS in Chrome DevTools, save changes to source as Tailwind classes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@shiage/core": "workspace:*",
    "@shiage/jsx-transform": "workspace:*",
    "@shiage/runtime": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.0",
    "@types/node": "^25.9.0",
    "vite": "^8.0.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
